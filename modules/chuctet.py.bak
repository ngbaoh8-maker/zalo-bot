import os
import time
import threading
from zlapi.models import Message
import zlapi

# ================= INFO =================
des = {
    'version': "4.0.0",
    'credits': "DucDuy",
    'description': "Tự động gửi tin nhắn chúc Tết + Tag All",
    'power': "Admin"
}

TXT_FILE = "modules/cache/chuctet.txt"

# Biến toàn cục kiểm soát trạng thái
loop_status = {}

# ================= UTIL =================
def get_all_wishes():
    if os.path.exists(TXT_FILE):
        with open(TXT_FILE, "r", encoding="utf-8") as f:
            return [line.strip() for line in f.readlines() if line.strip()]
    return ["Chúc mừng năm mới An Khang Thịnh Vượng!"]

# ================= LOOP TASK =================
def start_text_loop(thread_id, thread_type, client):
    while loop_status.get(thread_id, False):
        all_wishes = get_all_wishes()
        
        for wish in all_wishes:
            if not loop_status.get(thread_id, False):
                break
                
            try:
                # Nội dung tin nhắn kèm Tag All
                msg_text = f"📢 @All\n🧧 {wish}"
                
                # Gửi tin nhắn văn bản
                client.send(
                    Message(text=msg_text), 
                    thread_id=thread_id, 
                    thread_type=thread_type
                )
            except Exception as e:
                print(f"Lỗi gửi tin nhắn: {e}")
                loop_status[thread_id] = False
                break
            
            # Thời gian nghỉ 3 giây để tránh bị Zalo khóa acc
            time.sleep(3)

# ================= COMMAND =================
def handle_chuctet(message, message_object, thread_id, thread_type, author_id, client):
    # Lệnh bắt đầu: .chuctet
    if loop_status.get(thread_id, False):
        return client.replyMessage(Message(text="⚠️ Bot đang trong chế độ gửi lời chúc rồi!"), message_object, thread_id, thread_type)
    
    loop_status[thread_id] = True
    client.replyMessage(Message(text="🚀 Đã bật tự động chúc Tết. Gõ '.hettet' để dừng."), message_object, thread_id, thread_type)
    
    # Chạy luồng riêng để không treo bot
    threading.Thread(target=start_text_loop, args=(thread_id, thread_type, client), daemon=True).start()

def handle_hettet(message, message_object, thread_id, thread_type, author_id, client):
    # Lệnh dừng: .hettet
    if not loop_status.get(thread_id, False):
        return client.replyMessage(Message(text="⚠️ Hiện tại bot không chạy gửi lời chúc."), message_object, thread_id, thread_type)
    
    loop_status[thread_id] = False
    client.replyMessage(Message(text="🛑 Đã dừng gửi tin nhắn chúc Tết thành công!"), message_object, thread_id, thread_type)

# ================= EXPORT =================
def PTA():
    return {
        'chuctet': handle_chuctet,
        'hettet': handle_hettet
    }