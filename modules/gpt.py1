from zlapi.models import Message, ThreadType
from config import PREFIX
import logging
import requests
import json

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

des = {
    'version': "1.0.0",
    'credits': "DucDuydzai cuto",
    'description': "Hỏi ChatGPT với mọi nội dung",
    'power': "Người dùng"
}

# 👉 ĐIỀN API KEY CỦA BẠN vào đây hoặc dùng biến môi trường OPENAI_API_KEY
import os
OPENAI_API_KEY = os.environ.get("OPENAI_API_KEY", "sk-your-openai-api-key-here")

class GPTHandler:
    def __init__(self, client):
        self.client = client

    def handle_gpt_command(self, message_text, message_object, thread_id, thread_type, author_id):
        try:
            parts = message_text.split(maxsplit=1)
            command = parts[0].lstrip(PREFIX)

            if command != "gpt":
                return

            if len(parts) < 2:
                self.client.replyMessage(
                    Message(text=f"🤖 Cách dùng:\n{PREFIX}gpt <câu hỏi>"),
                    message_object, thread_id, thread_type, ttl=60000
                )
                return

            prompt = parts[1]

            # Gửi request lên OpenAI
            response = requests.post(
                "https://api.openai.com/v1/chat/completions",
                headers={
                    "Authorization": f"Bearer {OPENAI_API_KEY}",
                    "Content-Type": "application/json"
                },
                json={
                    "model": "gpt-3.5-turbo",
                    "messages": [
                        {"role": "system", "content": "Bạn là trợ lý AI thân thiện, trả lời bằng tiếng Việt."},
                        {"role": "user", "content": prompt}
                    ],
                    "temperature": 0.7
                },
                timeout=30
            )

            data = response.json()

            if "choices" not in data:
                raise Exception(data)

            answer = data["choices"][0]["message"]["content"].strip()

            self.client.replyMessage(
                Message(text=f"🤖 ChatGPT trả lời:\n\n{answer}"),
                message_object, thread_id, thread_type, ttl=120000
            )

        except Exception as e:
            logger.error(f"[GPT] Lỗi: {e}")
            self.client.replyMessage(
                Message(text="❌ Lỗi khi hỏi ChatGPT, vui lòng thử lại sau."),
                message_object, thread_id, thread_type, ttl=60000
            )

def PTA():
    return {
        'gpt': GPTHandler
    }
