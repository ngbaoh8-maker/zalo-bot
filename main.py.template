    def onEvent(self, event_data, event_type):
        handleGroupEvent(self, event_data, event_type)

        # --- Trigger handle_bot_invited chỉ khi bot được mời ---
        try:
            etype_str = str(event_type)
            if etype_str == "GroupEventType.JOIN":
                thread_id = event_data.get("groupId", None) if isinstance(event_data, dict) else getattr(event_data, "groupId", None)
                author_id = event_data.get("creatorId", None) if isinstance(event_data, dict) else getattr(event_data, "creatorId", None)
                joined_ids = event_data.get("updateMembers", []) if isinstance(event_data, dict) else getattr(event_data, "updateMembers", [])

                if thread_id is None or author_id is None:
                    return

                # Kiểm tra bot có trong danh sách mới join không
                bot_joined = any(member.get("id") == self.uid for member in joined_ids)
                if not bot_joined:
                    return

                print(f"[DEBUG] Trigger handle_bot_invited cho bot tại groupId={thread_id}")
                self.handle_bot_invited(event_data, thread_id, "group", author_id)
        except Exception as e:
            print(f"[ERROR] Exception in handle_bot_invited trigger: {e}")
            logger.error(f"🚦 Lỗi khi trigger handle_bot_invited: {e}")
    
    def handle_bot_invited(self, message_object, thread_id, thread_type=None, author_id=None):
        try:
            import time
            from zlapi.models import ThreadType

            # --- ThreadType fallback ---
            if thread_type is None:
                thread_type = ThreadType.GROUP

            if isinstance(thread_type, str):
                if thread_type.lower() == "group":
                    thread_type = ThreadType.GROUP
                else:
                    thread_type = ThreadType.USER

            # --- Chờ bot join thật sự ---
            joined = False
            # Giảm số lần thử và delay để tăng tốc độ
            for i in range(5):
                try:
                    info = self.fetchGroupInfo(thread_id)
                    if info and info.gridInfoMap.get(thread_id):
                        joined = True
                        break
                except:
                    pass
                if not joined:
                    time.sleep(0.3)  # Giảm delay từ 0.7s xuống 0.3s

            if not joined:
                print("❌ Bot chưa join xong → không thể rời")
                return

            # --- Lấy tên người mời ---
            creator_id = getattr(message_object, 'creatorId', author_id)
            try:
                user_info = self.fetchUserInfo(creator_id).changed_profiles.get(creator_id, {})
                chubox_name = user_info.get('displayName', str(creator_id))
            except:
                chubox_name = str(creator_id)

            msg = (
                f"➜ /-li Anti invite /-li\n"
                f"➜ 👑 Mời Thằng Bố ;-! {chubox_name} ;-! Mày à, Beta ? "
            )
            msg_len = len(msg)

            styles = MultiMsgStyle([
                MessageStyle(offset=4, length=4, style="color", color="#DB342E"),
                MessageStyle(offset=28, length=len(chubox_name), style="color", color="#DB342E"),
                MessageStyle(offset=0, length=msg_len, style="bold", size=12),
                MessageStyle(offset=0, length=msg_len, style="italic"),
                MessageStyle(offset=0, length=msg_len, style="color", color="#15A85F")
            ])

            message = Message(text=msg, style=styles)

            # --- Gửi tin ---
            self.send(message, thread_id=thread_id, thread_type=thread_type, ttl=20000)

            # --- Giảm delay từ 1.5s xuống 0.5s để bot phản hồi nhanh hơn ---
            time.sleep(0.5)

            # --- TÌM HÀM RỜI NHÓM ĐÚNG TRONG ZLAPI ---
            leave_methods = [
                "leaveGroup",
                "leave_group",
                "exitGroup",
                "quitGroup",
                "groupLeave"
            ]

            left = False
            for method in leave_methods:
                if hasattr(self, method):
                    getattr(self, method)(thread_id)
                    print(f"✅ Rời nhóm bằng method: {method}")
                    left = True
                    break

            if not left:
                print("❌ Không tìm thấy hàm rời nhóm trong client!")

        except Exception as e:
            print(f"[ERROR] Exception trong handle_bot_invited: {e}")
            logger.error(f"🚦 Lỗi khi trigger handle_bot_invited: {e}")
   
